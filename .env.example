# Copy these to Railway environment variables dashboard

JIRA_URL=https://lla.atlassian.net
JIRA_EMAIL=gowtham.krishna@libertypr.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECT_KEY=SAC
JIRA_ASSIGNEES=gowtham.krishna@libertypr.com
JIRA_CUSTOM_JQL=project = SAC AND status in ("In Progress","Waiting for support", "Escalated") and "Reporting Area[Dropdown]" = "Order Fallout" and Assignee in (EMPTY) ORDER BY created ASC
JIRA_ONLY_UNASSIGNED=true
JIRA_DRY_RUN=false
JIRA_SCHEDULE_CRON=0 */1 * * * *
