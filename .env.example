JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_api_token_here
JIRA_CUSTOM_JQL=project = SAC AND status in ("In Progress","Waiting for support","Escalated") and "Reporting Area[Dropdown]" = "Order Fallout" and Assignee in (EMPTY) ORDER BY created ASC
JIRA_DRY_RUN=false
